<Window x:Class="DSRemote.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DSRemote" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="{Binding BackgroundBrush}" BorderThickness="0 0 0 1"
                BorderBrush="#333" MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid Margin="8 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- MacOS-style buttons on LEFT -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Width="14" Height="14" Margin="0 0 8 0"
                            Background="#FF5F57" BorderThickness="0"
                            ToolTip="Close" Click="Close_Click">
                        <Button.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="2" Opacity="0.5"/>
                        </Button.Effect>
                    </Button>
                    <Button Width="14" Height="14" Margin="0 0 8 0"
                            Background="#FEBC2E" BorderThickness="0"
                            ToolTip="Minimize" Click="Minimize_Click">
                        <Button.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="2" Opacity="0.5"/>
                        </Button.Effect>
                    </Button>
                    <Button Width="14" Height="14"
                            Background="#28C840" BorderThickness="0"
                            ToolTip="Fullscreen" Click="Maximize_Click">
                        <Button.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="2" Opacity="0.5"/>
                        </Button.Effect>
                    </Button>
                </StackPanel>

                <!-- App Info -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Border Width="20" Height="20" CornerRadius="4"
                            Background="{Binding AccentColor, Converter={StaticResource ColorToBrush}}"
                            Margin="0 0 8 0"/>
                    <TextBlock Text="DSRemote" FontSize="14" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center"/>
                    <Ellipse Width="6" Height="6" Fill="{Binding IsConnected, Converter={StaticResource BoolToColor}}"
                             Margin="10 0 6 0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#999"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right side: Disconnect + Settings -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="DisconnectBtn" Padding="10 4"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}}"
                            MouseLeftButtonDown="Disconnect_Click"
                            CornerRadius="4" Cursor="Hand">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#e94560" Offset="0"/>
                                <GradientStop Color="#FEBC2E" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="Disconnect" Foreground="White" FontSize="11"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Text="⚙" FontSize="16" Foreground="#666"
                               Margin="12 0 0 0" Cursor="Hand"
                               MouseLeftButtonDown="Settings_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="10" Background="{Binding BackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Phone Screen View -->
            <Border Grid.Column="0" Background="{Binding BackgroundBrush}" CornerRadius="10" Padding="15"
                    BorderThickness="1" BorderBrush="#0f3460" Margin="0 0 5 0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Phone View" FontSize="14" FontWeight="SemiBold"
                               Foreground="#888" Margin="0 0 0 10"/>

                    <Border Grid.Row="1" Background="{Binding BackgroundBrush}" CornerRadius="8"
                            BorderThickness="1" BorderBrush="{Binding AccentColor, Converter={StaticResource ColorToBrush}}">
                        <Grid>
                            <Image x:Name="PhoneScreenImage" Source="{Binding PhoneScreenImage}"
                                   Stretch="Uniform" Margin="10"/>
                            <TextBlock x:Name="NoPhoneText"
                                       Text="No phone connected.&#x0a;Connect via USB or WiFi to start."
                                       FontSize="16" Foreground="#555"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       TextWrapping="Wrap" TextAlignment="Center"
                                       Visibility="{Binding IsConnected, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Separator -->
            <GridSplitter Grid.Column="1" Width="4" Margin="5 0"
                          Background="#0f3460" HorizontalAlignment="Center"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Right: Game Library -->
            <Border Grid.Column="2" Background="{Binding BackgroundBrush}" CornerRadius="10" Padding="15"
                    BorderThickness="1" BorderBrush="#0f3460" Margin="5 0 0 0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Game Library" FontSize="14"
                                   FontWeight="SemiBold" Foreground="#888"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Refresh" Padding="10 4"
                                Background="#0f3460" Foreground="White" BorderThickness="0"
                                Click="RefreshGames_Click"/>
                    </Grid>

                    <TextBox x:Name="SearchBox" Grid.Row="1" Margin="0 10"
                             Padding="8" FontSize="13"
                             Background="#0d1117" Foreground="White"
                             BorderThickness="1" BorderBrush="{Binding AccentColor, Converter={StaticResource ColorToBrush}}"
                             TextChanged="Search_TextChanged"/>

                    <ListBox x:Name="GameList" Grid.Row="2"
                             ItemsSource="{Binding Games}"
                             Background="{Binding BackgroundBrush}" Foreground="White"
                             BorderThickness="1" BorderBrush="{Binding AccentColor, Converter={StaticResource ColorToBrush}}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="GameList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10 8" Margin="2"
                                        Background="#16213e" CornerRadius="6"
                                        BorderThickness="1" BorderBrush="#0f3460">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="36" Height="36"
                                                CornerRadius="6" Margin="0 0 10 0"
                                                Background="{Binding Platform, Converter={StaticResource PlatformToColor}}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Platform, Converter={StaticResource PlatformToInitial}}"
                                                       Foreground="White" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="14"
                                                       FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding SizeFormatted}" FontSize="11"
                                                       Foreground="#888"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Play"
                                                Padding="12 4" Background="#32CD32"
                                                Foreground="White" BorderThickness="0"
                                                Click="PlayGame_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom Bar: IP & Port -->
        <Border Grid.Row="2" Background="#0d1117" Padding="12 0"
                BorderThickness="0 1 0 0" BorderBrush="#333">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="IP: " FontSize="11" Foreground="#666"/>
                    <TextBlock Text="{Binding LocalIPAddress}" FontSize="11" Foreground="#aaa"
                               FontFamily="Consolas"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="Port: " FontSize="11" Foreground="#666"/>
                    <TextBlock Text="{Binding Port}" FontSize="11" Foreground="#aaa"
                               FontFamily="Consolas"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding StatusText}" FontSize="11"
                           Foreground="#666" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Slide-out Menu -->
        <Border x:Name="SlideMenu" Grid.RowSpan="3"
                Width="220" HorizontalAlignment="Left"
                Background="#0f3460" Margin="-220 0 0 0"
                MouseEnter="SlideMenu_MouseEnter">
            <StackPanel Margin="15" VerticalAlignment="Center">
                <Border Width="64" Height="64" CornerRadius="12"
                        Background="{Binding AccentColor, Converter={StaticResource ColorToBrush}}"
                        HorizontalAlignment="Center" Margin="0 0 0 20"/>
                <TextBlock Text="DSRemote" FontSize="18" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" Margin="0 0 0 30"/>
                <Button Content="Stop Emulation" Padding="10" Margin="0 0 0 10"
                        Background="#e94560" Foreground="White" BorderThickness="0"
                        Click="StopEmulation_Click"/>
                <Button Content="Disconnect" Padding="10" Margin="0 0 0 10"
                        Background="#e94560" Foreground="White" BorderThickness="0"
                        Click="Disconnect_Click"/>
                <Button Content="Input Bindings" Padding="10" Margin="0 0 0 10"
                        Background="#16213e" Foreground="White" BorderThickness="0"
                        Click="InputBindings_Click"/>
                <Button Content="Settings" Padding="10" Margin="0 0 0 10"
                        Background="#16213e" Foreground="White" BorderThickness="0"
                        Click="Settings_Click"/>
                <Separator Background="#1a1a2e" Margin="0 20"/>
                <TextBlock Text="Connected Devices" FontSize="12" Foreground="#888"
                           HorizontalAlignment="Center" Margin="0 0 0 10"/>
                <TextBlock Text="{Binding DeviceName, FallbackValue='Not connected'}"
                           FontSize="13" Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
