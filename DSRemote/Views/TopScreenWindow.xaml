<Window x:Class="DSRemote.Views.TopScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="3DS - Top Screen" Height="480" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e" WindowStyle="None"
        AllowsTransparency="True" Topmost="True"
        MouseDown="Window_MouseDown"
        KeyDown="Window_KeyDown">
    <Grid>
        <Border CornerRadius="12" Background="#1a1a2e" BorderThickness="1" BorderBrush="#0f3460" Margin="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0" Background="#16213e" CornerRadius="8 8 0 0" Padding="10 6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="3DS - Top Screen" FontSize="13"
                                   Foreground="#888" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="FullscreenBtn" Content="⛶" Width="28" Height="24"
                                    Background="#0f3460" Foreground="White" BorderThickness="0"
                                    Margin="0 0 6 0" Click="ToggleFullscreen_Click"/>
                            <Button Content="✕" Width="28" Height="24"
                                    Background="#e94560" Foreground="White" BorderThickness="0"
                                    Click="Close_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Screen display -->
                <Image Grid.Row="1" x:Name="TopScreenImage"
                       Stretch="Uniform" Margin="8"
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <!-- Status bar -->
                <Border Grid.Row="2" Background="#16213e" CornerRadius="0 0 8 8" Padding="8 4">
                    <TextBlock x:Name="StatusText" Text="Streaming top screen..."
                               FontSize="11" Foreground="#666"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
