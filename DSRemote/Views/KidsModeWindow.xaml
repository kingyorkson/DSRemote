<Window x:Class="DSRemote.Views.KidsModeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kids Mode" Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" FontFamily="Segoe UI"
        ResizeMode="NoResize">
    <Grid>
        <!-- Background image -->
        <Image x:Name="BgImage" Stretch="UniformToFill"/>

        <!-- Overlay for readability -->
        <Rectangle Fill="#80000000"/>

        <!-- Content -->
        <ScrollViewer VerticalScrollBarVisibility="Hidden">
            <StackPanel Margin="30" VerticalAlignment="Center">
                <!-- Title -->
                <TextBlock Text="🎮 Kids Mode" FontSize="28" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"
                           Margin="0 0 0 20"/>

                <!-- Age selector -->
                <TextBlock Text="Select Age:" FontSize="16" Foreground="#ccc"
                           Margin="0 0 0 5"/>
                <TextBlock x:Name="AgeDisplay" Text="Age: 6" FontSize="22"
                           Foreground="White" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0 0 0 5"/>
                <Slider x:Name="AgeSlider" Minimum="1" Maximum="18"
                        Value="6" TickFrequency="1" IsSnapToTickEnabled="True"
                        Margin="10 0 10 20"
                        ValueChanged="AgeSlider_ValueChanged"
                        Foreground="#32CD32"/>

                <Border CornerRadius="12" Background="#16213e" Padding="20"
                        Margin="0 0 0 20">
                    <StackPanel>
                        <StackPanel x:Name="ContentPanel">
                        <!-- Lock Screen (has password) -->
                        <StackPanel x:Name="LockPanel" Visibility="Collapsed">
                            <TextBlock Text="Welcome back!" FontSize="22"
                                       Foreground="White" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0 0 0 10"/>
                            <TextBox x:Name="LockPasswordBox"
                                     TextChanged="LockPassword_TextChanged"
                                     MaxLength="4" FontSize="32"
                                     HorizontalAlignment="Center"
                                     Width="120" TextAlignment="Center"
                                     Background="#0d1117" Foreground="White"
                                     BorderBrush="#0f3460" BorderThickness="2"
                                     CaretBrush="White"/>
                            <TextBlock x:Name="LockError" Text="" FontSize="12"
                                       Foreground="#e94560"
                                       HorizontalAlignment="Center"/>
                            <Button x:Name="UnlockBtn" Content="Unlock"
                                    Width="140" Padding="12 8" Margin="0 15 0 0"
                                    Background="#32CD32" Foreground="White"
                                    BorderThickness="0" Click="Unlock_Click"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Setup Screen (first time) -->
                        <StackPanel x:Name="SetupPanel" Visibility="Collapsed">
                            <TextBlock Text="Set a 4-digit PIN:" FontSize="18"
                                       Foreground="White" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0 0 0 5"/>
                            <TextBlock Text="(Enter 4 digits to create your password)"
                                       FontSize="12" Foreground="#888"
                                       HorizontalAlignment="Center"
                                       Margin="0 0 0 10"/>
                            <TextBox x:Name="NewPasswordBox"
                                     TextChanged="NewPassword_TextChanged"
                                     MaxLength="4" FontSize="32"
                                     HorizontalAlignment="Center"
                                     Width="120" TextAlignment="Center"
                                     Background="#0d1117" Foreground="White"
                                     BorderBrush="#0f3460" BorderThickness="2"
                                     CaretBrush="White"/>
                            <TextBlock x:Name="SymbolPreview" Text="" FontSize="14"
                                       Foreground="#32CD32" FontFamily="Consolas"
                                       HorizontalAlignment="Center"
                                       Margin="0 5 0 0"/>
                            <Button x:Name="SetPasswordBtn" Content="Set PIN"
                                    Width="140" Padding="12 8" Margin="0 15 0 0"
                                    Background="#32CD32" Foreground="White"
                                    BorderThickness="0" Click="SetPassword_Click"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Connected Screen -->
                        <StackPanel x:Name="ConnectedPanel" Visibility="Collapsed">
                            <TextBlock Text="📱" FontSize="60"
                                       HorizontalAlignment="Center"
                                       Margin="0 0 0 10"/>
                            <TextBlock x:Name="ConnectStatusText"
                                       Text="Please connect a device"
                                       FontSize="18" Foreground="White"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0 0 0 10"/>
                            <TextBlock Text="Open DSRemote on your phone and connect to this PC."
                                       FontSize="13" Foreground="#888"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                        </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Close button -->
                <Button x:Name="CloseKidsBtn" Content="Exit Kids Mode"
                        Width="160" Padding="10 8"
                        Background="#e94560" Foreground="White"
                        BorderThickness="0" Click="CloseKids_Click"
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
