<Window x:Class="DSRemote.Views.SetupWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DSRemote Setup" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize" Background="#1a1a2e"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#16213e" Padding="20 15">
            <TextBlock x:Name="StepTitle" Text="Welcome!" FontSize="22" FontWeight="SemiBold"
                       Foreground="White"/>
        </Border>

        <Frame x:Name="ContentFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>

        <Border Grid.Row="2" Background="#16213e" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock x:Name="StepIndicator" Text="Step 1 of 5" FontSize="14"
                               Foreground="#888" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="BackBtn" Content="Back" Width="80" Margin="0 0 10 0"
                            Padding="8 5" Click="Back_Click"
                            Background="#0f3460" Foreground="White" BorderThickness="0"/>
                    <Button x:Name="NextBtn" Content="Next" Width="80" Padding="8 5"
                            Click="Next_Click"
                            Background="#e94560" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
