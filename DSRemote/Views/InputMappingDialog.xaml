<Window x:Class="DSRemote.Views.InputMappingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure Input Bindings" Height="500" Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" FontFamily="Segoe UI"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">
    <Border Background="#1a1a2e" CornerRadius="10" BorderThickness="1" BorderBrush="#0f3460">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Input Bindings" FontSize="20" FontWeight="Bold"
                       Foreground="White" Margin="0 0 0 15"/>

            <ScrollViewer Grid.Row="1">
                <StackPanel x:Name="BindingsPanel">
                    <TextBlock Text="Select a button, then press a key on your keyboard to bind it."
                               FontSize="13" Foreground="#999" TextWrapping="Wrap" Margin="0 0 0 15"/>
                </StackPanel>
            </ScrollViewer>

            <TextBlock x:Name="StatusText" Grid.Row="2" FontSize="13"
                       Foreground="#ffcc00" Margin="0 10" HorizontalAlignment="Center"/>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ResetBtn" Content="Reset to Defaults" Padding="12 8"
                        Background="#e94560" Foreground="White" BorderThickness="0"
                        Click="Reset_Click" Margin="0 0 10 0"/>
                <Button Content="Save" Padding="20 8"
                        Background="#32CD32" Foreground="White" BorderThickness="0"
                        Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>